{
  "name": "replicant-2049",
  "version": "2.3.0",
  "description": "Replicant 2049 - AI-powered project documentation generator & full-stack scaffolding. Generate SRS/PLAN/README via GitHub Models, export to HTML/MP4, scaffold Express+React projects.",
  "type": "module",
  "bin": {
    "replicant": "./src/cli.mjs"
  },
  "main": "./src/export-html.mjs",
  "exports": {
    ".": "./src/export-html.mjs",
    "./video": "./src/export-video.mjs",
    "./themes/*": "./src/themes/*"
  },
  "scripts": {
    "init": "node src/init-project.mjs",
    "sync": "node src/sync-docs.mjs",
    "generate": "node src/generate-docs.mjs",
    "generate:all": "node src/generate-docs.mjs --all",
    "export": "node src/cli.mjs export",
    "export:video": "node src/cli.mjs export --video",
    "export:all": "node src/cli.mjs export --html --video",
    "example": "node src/cli.mjs export --config example/tutorial.config.js"
  },
  "keywords": [
    "tutorial",
    "html",
    "video",
    "markdown",
    "generator",
    "documentation",
    "scaffolding",
    "boilerplate",
    "screenshots",
    "playwright",
    "ffmpeg",
    "shadcn",
    "mp4"
  ],
  "author": "CamiloIncba",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CamiloIncba/replicant-2049.git"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "marked": "^17.0.0",
    "playwright": "^1.58.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
